# Docker Compose environment variables
# Copy to .env in the project root: cp .env.docker.example .env

# Port to expose VibeFocus on (default: 8000)
VIBEFOCUS_PORT=8000

# Path to your local development directory (where your git repos live).
# Enables git sync, code analysis, and code-aware AI chat.
# Example: /Users/you/Development or /home/you/code
PROJECTS_DIR=
